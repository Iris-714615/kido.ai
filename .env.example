DATABASE_URL=mysql+pymysql://kido:kido@mysql:3306/kidoai?charset=utf8mb4
REDIS_URL=redis://redis:6379/0
STORAGE_DIR=/data/uploads
SECRET_KEY=change-me
API_CORS_ALLOW_ORIGINS=*
AI_PROVIDER=fallback

# OpenAI Configuration (optional)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Coze Configuration (optional - set AI_PROVIDER=coze to use)
COZE_API_KEY=your-coze-pat-token-here
COZE_API_BASE=https://api.coze.cn
COZE_TIMEOUT=30
COZE_CHAT_WORKFLOW_ID=kidoai-chat-reply
COZE_EXPLORE_WORKFLOW_ID=kidoai-explore-analysis
COZE_SUMMARY_WORKFLOW_ID=kidoai-memory-summary
COZE_BOT_ID=7654142913093386294
COZE_USER_ID_PREFIX=kidoai_chat_reply

# Demo Account
DEMO_USERNAME=demo_child
DEMO_PASSWORD=demo123
DEMO_NICKNAME=小探险家
DEMO_AGE=6

# RAG 多轮对话历史最少保留轮数（1 轮 = 1 次提问 + 1 次回答，最小值 5）
RAG_HISTORY_MIN_TURNS=5

# ========== 短信通知 ==========
# SMS_PROVIDER：fallback（Mock）/ aliyun
SMS_PROVIDER=fallback
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE_OTP=
ALIYUN_SMS_TEMPLATE_CODE_RECHARGE=
ALIYUN_SMS_TEMPLATE_CODE_REPORT=

# ========== 邮件通知 ==========
# EMAIL_PROVIDER：fallback（Mock）/ resend / smtp
EMAIL_PROVIDER=fallback
RESEND_API_KEY=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_SENDER=

# ========== 支付 ==========
# 支付宝
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=
# 微信支付
WECHAT_MCH_ID=
WECHAT_API_V3_KEY=
WECHAT_NOTIFY_URL=

# ========== Coze ==========
# 已在上方配置，此处仅作分组提示：
# COZE_API_KEY / COZE_API_BASE / COZE_TIMEOUT
# COZE_CHAT_WORKFLOW_ID / COZE_EXPLORE_WORKFLOW_ID / COZE_SUMMARY_WORKFLOW_ID
# COZE_BOT_ID / COZE_USER_ID_PREFIX

# ========== 通义万相（绘本图片） ==========
DASHSCOPE_API_KEY=

# ========== LangSmith 追踪（可选） ==========
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_PROJECT=kidoai-parent-chat

# ========== TTS 语音合成 ==========
TTS_PROVIDER=fallback
TTS_MODEL=cosyvoice-v1
TTS_VOICE=longxiaochun
TTS_SAMPLE_RATE=22050

# ========== Neo4j 知识图谱 ==========
# 默认连接本地 Docker 启动的 neo4j 容器
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=123456abc
# Gradio 界面端口
NEO4J_GRADIO_HOST=0.0.0.0
NEO4J_GRADIO_PORT=7861